# =============================================================================
# AquaTerra Community Platform - Environment Configuration
# =============================================================================
# IMPORTANT: Copy this file to .env and fill in your values
# NEVER commit the .env file to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
PORT=5001
NODE_ENV=development
# Set to 'production' in production environments

# Trust proxy setting for deployments behind reverse proxy (nginx, load balancer)
# Set to 1 for single proxy, 2 for two proxies, 'loopback' for localhost only
# TRUST_PROXY=1

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aquaterra_community
DB_USER=postgres
DB_PASSWORD=your_secure_database_password_here

# -----------------------------------------------------------------------------
# JWT Configuration
# IMPORTANT: Generate strong random secrets for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_SECRET=GENERATE_A_64_CHAR_RANDOM_STRING_FOR_PRODUCTION
JWT_REFRESH_SECRET=GENERATE_ANOTHER_64_CHAR_RANDOM_STRING_FOR_PRODUCTION
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# -----------------------------------------------------------------------------
# Azure Blob Storage
# -----------------------------------------------------------------------------
# For local development with Azurite emulator:
# AZURE_STORAGE_CONNECTION_STRING=UseDevelopmentStorage=true
# For production, use your actual connection string:
AZURE_STORAGE_CONNECTION_STRING=your_azure_storage_connection_string
AZURE_CONTAINER_NAME=community-posts
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name

# -----------------------------------------------------------------------------
# Frontend URL (for CORS)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
# In production, set to your actual frontend domain (e.g., https://app.example.com)

# -----------------------------------------------------------------------------
# Google OAuth
# Get these from Google Cloud Console: https://console.cloud.google.com/
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# -----------------------------------------------------------------------------
# Super Admin Configuration (Optional)
# Set this to auto-promote a specific email to super admin on login
# Leave unset to disable auto-promotion
# -----------------------------------------------------------------------------
# SUPER_ADMIN_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# Development Only Settings
# WARNING: Never enable these in production!
# -----------------------------------------------------------------------------
# ALLOW_DEV_AUTH=true
# This bypasses Google OAuth verification - NEVER enable in production
